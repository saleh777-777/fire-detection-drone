<?xml version="1.0"?>
<model>
  <name>thermal_camera_8bit</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <author>
    <name>your_name</name>
    <email>you@example.com</email>
  </author>

  <description>
    A small static box carrying an 8-bit thermal camera sensor, configured
    for Gazebo Harmonic (gz-sim 8.13). Publishes images on
    /thermal_camera_8bit/image. Clamped between 253.15 K and 673.15 K with
    a linear resolution of 3.0.
  </description>
</model>
